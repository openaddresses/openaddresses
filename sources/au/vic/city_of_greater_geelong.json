                "website": "https://www.geelongdataexchange.com.au/explore/dataset/roofprints-city-of-greater-geelong/information/",
                "conform": {
                    "format": "geojson",
                    "height": "roof_ht"
                },
                "license": {
                    "text": "CC BY 3.0 AU",
                    "url": "https://creativecommons.org/licenses/by/3.0/au/",
                    "attribution name": "City of Greater Geelong",
                    "attribution": true,
