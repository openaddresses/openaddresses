{
    "coverage": {
        "country": "au",
        "state": "vic",
        "county": "Greater Geelong",
        "city": "City of Greater Geelong"
    },
    "schema": 2,
    "layers": {
        "addresses": [
            {
                "name": "city",
                "protocol": "http",
                "data": "https://data.gov.au/data/dataset/33425f27-c064-4fb3-8015-9370b2073409/resource/14392168-9351-4288-ba80-307d82fe9479/download/coggcadasterll.zip",
                "website": "https://data.gov.au/data/dataset/cadastre-land-and-property-boundaries-city-of-greater-geelong",
                "compression": "zip",
                "language": "en",
                "license": {
                    "url": "https://creativecommons.org/licenses/by/3.0/au/",
                    "text": "CC BY 3.0 AU",
                    "attribution": true,
                    "attribution name": "City of Greater Geelong",
                    "share-alike": false
                },
                "conform": {
                    "format": "shapefile",
                    "unit": {
                        "function": "regexp",
                        "field": "Unit",
                        "pattern": "^([1-9].*)"
                    },
                    "number": {
                        "function": "chain",
                        "variable": "number_wip",
                        "functions": [
                            {
                                "function": "remove_postfix",
                                "field": "FullAddres",
                                "field_to_remove": "PostCode"
                            },
                            {
                                "function": "regexp",
                                "field": "oa:number_wip",
                                "pattern": "^(.*)[ ]+VIC",
                                "replace": "$1"
                            },
                            {
                                "function": "remove_postfix",
                                "field": "oa:number_wip",
                                "field_to_remove": "Suburb"
                            },
                            {
                                "function": "regexp",
                                "field": "oa:number_wip",
                                "pattern": "^(.*),",
                                "replace": "$1"
                            },
                            {
                                "function": "remove_postfix",
                                "field": "oa:number_wip",
                                "field_to_remove": "Street"
                            },
                            {
                                "function": "regexp",
                                "field": "oa:number_wip",
                                "pattern": "^(.*)/(.*)",
                                "replace": "$2"
                            }
                        ]
                    },
                    "street": "Street",
                    "city": "Suburb",
                    "region": {
                        "function": "chain",
                        "variable": "region_wip",
                        "functions": [
                            {
                                "function": "remove_postfix",
                                "field": "FullAddres",
                                "field_to_remove": "PostCode"
                            },
                            {
                                "function": "regexp",
                                "field": "oa:region_wip",
                                "pattern": "^.*(VIC).*$",
                                "replace": "$1"
                            }
                        ]
                    },
                    "postcode": "PostCode"
                }
            }
        ],
        "parcels": [
            {
                "name": "city",
                "protocol": "http",
                "data": "https://data.gov.au/data/dataset/33425f27-c064-4fb3-8015-9370b2073409/resource/14392168-9351-4288-ba80-307d82fe9479/download/coggcadasterll.zip",
                "website": "https://data.gov.au/data/dataset/cadastre-land-and-property-boundaries-city-of-greater-geelong",
                "conform": {
