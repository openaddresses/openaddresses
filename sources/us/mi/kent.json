{
    "schema": 2,
    "coverage": {
        "US Census": {"geoid": "26081", "name": "Kent County", "state": "Michigan"},
        "country": "us",
        "state": "mi",
        "county": "Kent"
    },
    "layers": {
        "addresses": [
            {
                "name": "county",
                "data": "https://gis.kentcountymi.gov/agisprod/rest/services/ParcelsWithCondos/FeatureServer/0",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "number": {
                        "function": "prefixed_number",
                        "field": "PROPERTYADDRESS"
                    },
                    "street": {
                        "function": "postfixed_street",
                        "field": "PROPERTYADDRESS"
                    },
                    "city": "PROPADDRESSCITY",
                    "region": {
                        "function": "regexp",
                        "field": "PROPADDRESSSTATE_ZIPCODE",
                        "pattern": "^([A-Z]{2})([0-9]{5})",
                        "replace": "$1"
                    },
                    "postcode": {
                        "function": "regexp",
                        "field": "PROPADDRESSSTATE_ZIPCODE",
                        "pattern": "^([A-Z]{2})([0-9]{5})",
                        "replace": "$2"
                    }
                }
            }
        ],
        "buildings": [
            {
                "name": "county",
                "data": "https://gis.kentcountymi.gov/agisprod/rest/services/BuildingFootprints/MapServer/0",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson"
                }
            }
        ],
        "parcels": [
            {
                "name": "county",
                "data": "https://gis.kentcountymi.gov/agisprod/rest/services/FGDBParcels/MapServer/0",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "pid": "PPN"
                }
            }
        ],
        "centerlines": [
            {
                "name": "county",
                "data": "https://gis.kentcountymi.gov/agisprod/rest/services/Kent_Streets/MapServer/0",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "name": ["PREFIX_DIRECTION", "STREET_NAME", "STREET_SUFFIX", "SUFFIX_DIRECTION"],
                    "addr_from_left": "LEFT_START_ADDRESS",
                    "addr_to_left": "LEFT_END_ADDRESS",
                    "addr_from_right": "RIGHT_START_ADDRESS",
                    "addr_to_right": "RIGHT_END_ADDRESS",
                    "zip_left": "LEFT_ZIP_CODE",
                    "zip_right": "RIGHT_ZIP_CODE"
                }
            }
        ]
    }
}
