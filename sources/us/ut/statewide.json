                        },
                        "else": "no"
                    },
                    "speed": {
                        "function": "mph_to_kph",
                        "field": "SPEED_LMT"
                    },
                    "classification": {
                        "function": "map",
                        "field": "DOT_FCLASS",
                        "mapping": {
                            "Interstate": "motorway",
                            "Other Freeway": "trunk",
                            "Principal Arterial": "primary",
                            "Minor Arterial": "secondary",
                            "Major Collector": "tertiary",
                            "Minor Collector": "tertiary"
                        },
                        "else": "residential"
                    },
                    "surface": {
                        "function": "map",
                        "field": "DOT_SRFTYP",
                        "mapping": {
                            "P": "paved",
                            "P-ASP": "paved",
                            "P-CON": "paved",
                            "D": "unpaved",
                            "N": "unpaved"
                        },
                        "else": ""
                    },
                    "addr_from_left": "FROMADDR_L",
                    "addr_to_left": "TOADDR_L",
                    "addr_from_right": "FROMADDR_R",
                    "addr_to_right": "TOADDR_R",
                    "zip_left": "ZIPCODE_L",
                    "zip_right": "ZIPCODE_R"
                }
            }
        ]
