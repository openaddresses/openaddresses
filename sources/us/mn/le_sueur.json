{
    "coverage": {
        "US Census": {
            "geoid": "27079",
            "name": "Le Sueur County",
            "state": "Minnesota"
        },
        "country": "us",
        "state": "mn",
        "county": "Le Sueur"
    },
    "schema": 2,
    "layers": {
        "parcels": [
            {
                "name": "county",
                "data": "https://gis.co.le-sueur.mn.us/server/rest/services/Cadastral/Parcels/MapServer/5",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "pid": "PARCEL_NUMBER"
                }
            }
        ],
        "centerlines": [
            {
                "name": "county",
                "data": "https://gis.co.le-sueur.mn.us/server/rest/services/Road_Centerlines/FeatureServer/0",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "name": {
                        "function": "join",
                        "fields": [
                            "Street_Pre_Dir",
                            "Street_Prefix",
                            "Street_Name",
                            "Street_Type",
                            "Street_Post_Dir"
                        ],
                        "separator": " "
                    },
                    "addr_from_left": "FROMLEFT",
                    "addr_to_left": "TOLEFT",
                    "addr_from_right": "FROMRIGHT",
                    "addr_to_right": "TORIGHT"
                }
            }
        ],
        "addresses": [
            {
                "name": "county",
                "data": "https://gis.co.le-sueur.mn.us/server/rest/services/LandRecords/Parcels/MapServer/1",
                "protocol": "ESRI",
                "conform": {
                    "format": "geojson",
                    "number": {
                        "function": "regexp",
                        "field": "PROPERTY_ADDRESS_LINE_1",
                        "pattern": "^([0-9]+)"
                    },
                    "street": {
                        "function": "regexp",
                        "field": "PROPERTY_ADDRESS_LINE_1",
                        "pattern": "^(?:[0-9]+) (.*)",
                        "replace": "$1"
                    },
                    "city": "PROPERTY_CITY",
                    "postcode": "PROPERTY_ZIP_6"
                }
            }
        ]
    }
}
